rules_version = '2';

// Posa Rosa — Firestore security rules
//
// The Netlify functions (create-order.js, finalize-order.js) now use the
// Firebase ADMIN SDK (netlify/functions/lib/firebaseAdmin.js). The Admin SDK
// runs as a trusted service account and BYPASSES these rules entirely, so the
// database can be fully closed to every client. No browser code reads or writes
// Firestore, so denying all client access has no user-facing impact.
//
// Paste into: Firebase Console → Firestore Database → Rules → Publish
//
// ⚠ Deploy this ONLY AFTER the Admin-SDK functions are live, otherwise the
//    (old client-SDK) functions would lose their Firestore access.

service cloud.firestore {
  match /databases/{database}/documents {
    // Deny all client access. Trusted server code uses the Admin SDK, which
    // bypasses these rules.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
